<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Review — {{FEATURE_TITLE}}</title>
  <link rel="stylesheet" href="spec.css">
</head>
<body>
<div class="page-wrap">

  <nav class="sidebar" aria-label="Table of contents">
    <p class="sidebar-title">Contents</p>
    <div id="toc-list"></div>
  </nav>

  <div class="main-content">
    <header class="spec-header">
      <h1>Review — {{FEATURE_TITLE}}</h1>
      <table class="meta-table">
        <tbody>
          <tr><th>Task ID</th>       <td><code>{{TASK_ID}}</code></td></tr>
          <tr><th>Feature slug</th>  <td><code>{{FEATURE_SLUG}}</code></td></tr>
          <tr><th>Reviewer</th>      <td>reviewer</td></tr>
          <tr><th>Review status</th> <td><span class="badge badge-pending">pending</span></td></tr>
        </tbody>
      </table>
    </header>

    <main>

      <section id="traceability">
        <h2>Traceability</h2>
        <p>
          Each row maps a requirement to its implementation and test evidence.
          Cell colors: <span class="badge badge-blocking">blocking</span> issue present,
          <span class="badge badge-warning">warning</span> minor concern,
          <span class="badge badge-ok">ok</span> verified.
        </p>
        <table>
          <thead>
            <tr>
              <th>Requirement</th>
              <th>Implemented?</th>
              <th>Tested?</th>
              <th>Evidence</th>
            </tr>
          </thead>
          <tbody>
            <!-- Reviewer: set class="blocking", "warning", or "ok" on each <td> as appropriate -->
            <tr>
              <td><span class="req-id">REQ-001</span></td>
              <td class="pending">TODO</td>
              <td class="pending">TODO</td>
              <td>TODO</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section id="commands-run">
        <h2>Commands run</h2>
        <pre><code>TODO</code></pre>
      </section>

      <section id="findings">
        <h2>Findings</h2>

        <div class="collapsible-section">
          <button class="collapse-btn" type="button">
            <span class="arrow">▾</span> Blocking findings
          </button>
          <div class="collapse-body">
            <p>TODO or <code>None</code>.</p>
            <!-- Add one entry per blocking finding:
            <div class="req-row err">
              <span class="req-id err">BLK-1</span>
              <span>Description of the blocking issue.</span>
            </div>
            -->
          </div>
        </div>

        <div class="collapsible-section">
          <button class="collapse-btn" type="button">
            <span class="arrow">▾</span> Non-blocking findings
          </button>
          <div class="collapse-body">
            <p>TODO or <code>None</code>.</p>
            <!-- Add one entry per non-blocking finding:
            <div class="req-row edge">
              <span class="req-id edge">NBK-1</span>
              <span>Description of the non-blocking concern.</span>
            </div>
            -->
          </div>
        </div>
      </section>

      <section id="decision">
        <h2>Decision</h2>
        <p>Reviewer selects one:</p>
        <table>
          <thead>
            <tr><th>Option</th><th>Meaning</th><th>Selected</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="badge badge-ok">approved</span></td>
              <td>Task can move to <code>done</code>.</td>
              <td>☐</td>
            </tr>
            <tr>
              <td><span class="badge badge-blocking">rejected</span></td>
              <td>Blocking defects found; return to <code>in_progress</code>.</td>
              <td>☐</td>
            </tr>
            <tr>
              <td><span class="badge badge-warning">needs_changes</span></td>
              <td>Non-blocking fixes required before <code>done</code>.</td>
              <td>☐</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section id="notes">
        <h2>Notes</h2>
        <p>TODO.</p>
      </section>

    </main>
  </div><!-- /.main-content -->
</div><!-- /.page-wrap -->
<script src="spec.js"></script>
</body>
</html>
