<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SDD History</title>
  <style>
    /* history.html is a project-root file with no spec folder, so styles are inline. */
    :root {
      --c-ok: #27ae60; --c-ok-bg: #eafaf1;
      --c-blocking: #c0392b; --c-blocking-bg: #fdecea;
      --c-warning: #e67e22; --c-warning-bg: #fef6ed;
      --c-border: #d1d5db; --c-bg-alt: #f9fafb;
      --c-text: #111827; --c-text-muted: #6b7280;
      --c-accent: #2563eb;
      --font-sans: system-ui, -apple-system, sans-serif;
      --font-mono: ui-monospace, Menlo, monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-sans); font-size: 15px; line-height: 1.65; color: var(--c-text); max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem; }
    h1 { font-size: 1.55rem; margin-bottom: 0.5rem; }
    h2 { font-size: 1.05rem; font-weight: 700; margin: 1.75rem 0 0.6rem; border-bottom: 1px solid var(--c-border); padding-bottom: 0.3rem; }
    p { margin: 0.6rem 0; }
    ul, ol { padding-left: 1.5rem; margin: 0.5rem 0; }
    li { margin: 0.25rem 0; }
    code { font-family: var(--font-mono); font-size: 0.875em; background: #e5e7eb; padding: 0.1em 0.4em; border-radius: 3px; }
    hr { border: none; border-top: 1px solid var(--c-border); margin: 1.5rem 0; }
    a { color: var(--c-accent); }
    .badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.15em 0.6em; border-radius: 9999px; text-transform: uppercase; }
    .badge-ok       { background: var(--c-ok-bg);       color: var(--c-ok); }
    .badge-blocking { background: var(--c-blocking-bg); color: var(--c-blocking); }
    .badge-warning  { background: var(--c-warning-bg);  color: var(--c-warning); }
    .entry {
      border-left: 3px solid var(--c-ok);
      padding: 0.85rem 1.1rem;
      margin: 1rem 0;
      background: var(--c-bg-alt);
      border-radius: 0 4px 4px 0;
    }
    .entry-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .entry-date {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--c-text-muted);
    }
    .entry-title { font-weight: 600; }
    dl.entry-fields { display: grid; grid-template-columns: 160px 1fr; gap: 0.3rem 0.75rem; font-size: 0.875rem; }
    dl.entry-fields dt { font-weight: 600; color: var(--c-text-muted); }
    dl.entry-fields dd { margin: 0; }
  </style>
</head>
<body>

  <h1>SDD History</h1>
  <p>This file records completed SDD work. Append a new entry each time a task reaches <code>done</code>.</p>

  <hr>

  <section id="entries">
    <h2>Entries</h2>

    <!-- ENTRY FORMAT — copy this block for each completed task, fill it in,
         and insert it immediately after the INSERT-ENTRY-HERE marker below
         (newest entry first). Remove the "No entries yet" paragraph when
         adding the first entry.

    <div class="entry">
      <div class="entry-header">
        <span class="entry-date">YYYY-MM-DD</span>
        <span class="badge badge-ok">done</span>
        <span class="entry-title">TASK-001 — feature-slug</span>
      </div>
      <dl class="entry-fields">
        <dt>Status</dt>            <dd>done</dd>
        <dt>Spec</dt>              <dd><code>specs/feature-slug/</code></dd>
        <dt>Summary</dt>           <dd>…</dd>
        <dt>Files changed</dt>     <dd>…</dd>
        <dt>Tests run</dt>         <dd>…</dd>
        <dt>Reviewer decision</dt> <dd><span class="badge badge-ok">approved</span></dd>
        <dt>Human approval ref</dt><dd>…</dd>
        <dt>Docs updated</dt>      <dd>… (targets updated, or "not required")</dd>
        <dt>Decisions recorded</dt><dd>… (decision-log/memory entries accepted by the developer, or "none")</dd>
        <dt>Follow-ups</dt>        <dd>…</dd>
      </dl>
    </div>

    -->

    <!-- INSERT-ENTRY-HERE -->

    <p style="color: var(--c-text-muted); font-style: italic;">No entries yet.</p>
  </section>

</body>
</html>
