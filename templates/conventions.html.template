<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conventions — {{PROJECT_NAME}}</title>
  <style>
    :root {
      --c-accent: #2563eb; --c-accent-bg: #eff6ff;
      --c-ok: #27ae60; --c-ok-bg: #eafaf1;
      --c-blocking: #c0392b; --c-blocking-bg: #fdecea;
      --c-border: #d1d5db; --c-bg-alt: #f9fafb;
      --c-text: #111827; --c-text-muted: #6b7280;
      --font-sans: system-ui, -apple-system, sans-serif;
      --font-mono: ui-monospace, Menlo, monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-sans); font-size: 15px; line-height: 1.65; color: var(--c-text); max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem; }
    h1 { font-size: 1.55rem; margin-bottom: 0.35rem; }
    .subtitle { color: var(--c-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
    h2 { font-size: 1.1rem; font-weight: 700; margin: 2rem 0 0.65rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(--c-border); }
    h3 { font-size: 0.95rem; font-weight: 600; margin: 1.1rem 0 0.4rem; }
    p { margin: 0.6rem 0; }
    ul, ol { padding-left: 1.5rem; margin: 0.5rem 0; }
    li { margin: 0.25rem 0; }
    code { font-family: var(--font-mono); font-size: 0.875em; background: #e5e7eb; padding: 0.1em 0.4em; border-radius: 3px; }
    pre { background: #1e1e2e; color: #cdd6f4; padding: 1rem 1.25rem; border-radius: 4px; overflow-x: auto; font-family: var(--font-mono); font-size: 0.84rem; margin: 1rem 0; }
    pre code { background: none; padding: 0; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin: 1rem 0; }
    th, td { border: 1px solid var(--c-border); padding: 0.5rem 0.75rem; text-align: left; }
    th { background: var(--c-bg-alt); font-weight: 600; }
    .rule { display: flex; gap: 0.5rem; align-items: flex-start; padding: 0.45rem 0.75rem; background: var(--c-blocking-bg); border-left: 3px solid var(--c-blocking); border-radius: 0 4px 4px 0; margin: 0.4rem 0; font-size: 0.875rem; }
    .rule-icon { font-weight: 700; color: var(--c-blocking); flex-shrink: 0; }
    hr { border: none; border-top: 1px solid var(--c-border); margin: 1.5rem 0; }
  </style>
</head>
