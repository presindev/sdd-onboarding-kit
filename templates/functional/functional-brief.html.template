    .toc-list { list-style: none; font-size: 0.82rem; }
    .toc-list li { margin-bottom: 0.4rem; }
    .toc-list a { color: var(--c-text-muted); text-decoration: none; }
    .toc-list a:hover { color: var(--c-accent); }
    .main-content { flex: 1; padding: 2rem 2.5rem; max-width: 900px; }
    .spec-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 2px solid var(--c-border); }
    .spec-header h1 { font-size: 1.55rem; font-weight: 700; margin-bottom: 0.5rem; }
    .callout { background: var(--c-warning-bg); border-left: 3px solid var(--c-warning); padding: 0.75rem 1rem; border-radius: 0 4px 4px 0; font-size: 0.9rem; margin: 0.75rem 0; }
    h2 { font-size: 1.1rem; font-weight: 700; margin: 2rem 0 0.65rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(--c-border); }
    h3 { font-size: 0.95rem; font-weight: 600; margin: 1.1rem 0 0.4rem; }
    p { margin: 0.6rem 0; }
    ul, ol { padding-left: 1.5rem; margin: 0.5rem 0; }
    li { margin: 0.25rem 0; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin: 1rem 0; }
    th, td { border: 1px solid var(--c-border); padding: 0.5rem 0.75rem; text-align: left; vertical-align: top; }
    th { background: var(--c-bg-alt); font-weight: 600; }
    code { font-family: var(--font-mono); font-size: 0.875em; background: #e5e7eb; padding: 0.1em 0.4em; border-radius: 3px; }
    pre { background: #1e1e2e; color: #cdd6f4; padding: 1rem 1.25rem; border-radius: 4px; overflow-x: auto; font-family: var(--font-mono); font-size: 0.84rem; margin: 1rem 0; }
    pre code { background: none; padding: 0; }
    .checkbox-list { list-style: none; padding: 0; margin: 0.5rem 0; }
    .checkbox-list li { display: flex; align-items: center; gap: 0.6rem; padding: 0.3rem 0; font-size: 0.9rem; }
    .checkbox-list li input { accent-color: var(--c-ok); width: 1rem; height: 1rem; }
    hr { border: none; border-top: 1px solid var(--c-border); margin: 1.5rem 0; }
    .section-num { color: var(--c-text-muted); font-weight: 400; font-size: 0.85em; margin-right: 0.35rem; }
    .claude-note { border: 1px dashed var(--c-accent); border-radius: 4px; padding: 0.85rem 1rem; background: var(--c-accent-bg); font-size: 0.85rem; margin: 1rem 0; }
    .claude-note h4 { color: var(--c-accent); margin-bottom: 0.5rem; }
    .output-tree { font-family: var(--font-mono); font-size: 0.85rem; background: var(--c-bg-alt); border: 1px solid var(--c-border); border-radius: 4px; padding: 1rem; margin: 0.75rem 0; }
    @media (max-width: 768px) {
